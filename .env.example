# Copy this file to .env and fill only the providers you plan to use.
# Keep .env local. It is intentionally ignored by git.

# Backend listener
TZ=Europe/Sofia
S2S_PORT=8765
S2S_BG_PORT=8766
S2S_SYSTEM_PROMPT=You are a helpful voice assistant. Keep replies short, warm, and spoken.
S2S_CHAT_SIZE=60
PARAKEET_TDT_MODEL_NAME=nvidia/parakeet-tdt-0.6b-v3
S2S_BG_STT_LANGUAGE=bg
S2S_LLM_REQUEST_TIMEOUT_S=120
QWEN3_TTS_MAX_NEW_TOKENS=3072

# Optional prebuilt Docker Hub images for docker-compose.hub.yml.
S2S_UI_IMAGE=desy0305/hf-realtime-voice-ui:latest
S2S_BACKEND_IMAGE=desy0305/speech-to-speech-backend:latest
ANI_VOICE_IMAGE=desy0305/ani-voice-api:91722a7

# Local LM Studio OpenAI-compatible server
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=google/gemma-4-12b-qat
LM_STUDIO_API_KEY=

# Optional isolated Qwen3 Omni realtime pilot at /omni.html.
# Leave base/key empty to reuse LM Studio settings. This requires a local
# server that actually exposes /v1/realtime; LM Studio may report unsupported.
QWEN_OMNI_BASE_URL=
QWEN_OMNI_MODEL=ggml-org/Qwen3-Omni-30B-A3B-Instruct-GGUF
QWEN_OMNI_API_KEY=
QWEN_OMNI_REQUIRE_LOCAL=1

# Optional CPU-only local wake word. Disabled by default.
WAKE_WORD_ENABLED=0
WAKE_WORD_BASE_URL=http://wake-word:8081
WAKE_WORD_PHRASE=HEY EVA
WAKE_WORD_SCORE=1.5
WAKE_WORD_THRESHOLD=0.25
WAKE_WORD_FOLLOWUP_S=20
WAKE_WORD_NUM_THREADS=1
WAKE_WORD_REQUIRE_LOCAL=1

# Optional isolated local Office agent. Disabled by default.
OFFICE_AGENT_ENABLED=0
OFFICE_AGENT_BASE_URL=http://office-agent:8082
OFFICE_AGENT_TOKEN=
OFFICE_AGENT_WORKSPACE=./agent-workspace
OFFICE_AGENT_REQUIRE_LOCAL=1
OFFICE_AGENT_REQUIRE_LOCAL_LLM=1
OFFICE_AGENT_LOCAL_LLM_PROVIDERS=lmstudio
OFFICE_AGENT_INTENT_TTL_S=60
OFFICE_AGENT_TIMEOUT_S=35

# Direct Cerebras OpenAI-compatible API
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gemma-4-31b
CEREBRAS_API_KEY=

# Cerebras through Hugging Face Inference Providers
HF_TOKEN=
HF_CEREBRAS_MODEL=google/gemma-4-31B-it:cerebras

# Gemini OpenAI-compatible API
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=

# BGGPT OpenAI-compatible API
BGGPT_URL=https://api.bggpt.ai/v1
BGGPT_MODEL=bggpt-gemma-3-27b
BGGPT_API_KEY=

# Optional JSON route table consumed by the OpenAI-compatible LLM handlers.
# The app can also provide this from docker compose.
LLM_PROVIDERS_JSON=

# Optional Bulgarian TTS experiment:
# docker compose -f docker-compose.bgtts-ani.yml --profile bgtts-ani up --build
# This starts a separate backend on S2S_BG_PORT and keeps the qwen3 profile unchanged.
ANI_VOICE_REV=91722a7fdd404cca1818ace44038ed43322fc66e
ANI_VOICE_PORT=8001
ANI_VOICE_API_URL=http://ani-voice-api:8000
ANI_VOICE_STYLE=F5
ANI_VOICE_SPEED=1.6
ANI_VOICE_TIMEOUT_S=120
ANI_VOICE_BLOCKSIZE=512
ANI_VOICE_MAX_TOKENS=1024
ANI_VOICE_PRELOAD=true
ANI_VOICE_CACHE_SPEAKER=true
ANI_VOICE_WARMUP_TEXT=Здравейте.
ANI_VOICE_REFERENCE_TEXT=Здравейте, радвам се да ви помогна.
ANI_VOICE_TIMING_LOGS=true
