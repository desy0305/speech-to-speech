# Copy to .env and fill only the provider you plan to use.

# UI
TZ=Europe/Sofia
UI_PORT=7860
UI_HTTPS_PORT=50056
LAN_HTTPS_CERT_DIR=./.local-https/certs
UI_HTTPS_AUTH_ENABLED=0
UI_HTTPS_AUTH_USER=
UI_HTTPS_AUTH_PASSWORD=
DIRECT_S2S_URL=http://localhost:8765
SAME_ORIGIN_S2S_PROXY=auto
SAME_ORIGIN_S2S_PATH=/s2s/v1/realtime
SAME_ORIGIN_BG_S2S_PATH=/s2s-bg/v1/realtime
ACTIVE_BACKEND=lmstudio
BACKEND_LABEL=LM Studio (local)
LLM_PROVIDER=LM Studio
DEFAULT_LLM_PROVIDER=lmstudio

# Optional Space web-search tool. Keep this server-side; never put it in browser code.
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERPER_API_KEY=

# LM Studio profile: docker compose -f docker-compose.local.yml --profile lmstudio up --build
# From Docker Desktop, host.docker.internal is usually best. The LAN URL also
# works if LM Studio is serving on the network.
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=google/gemma-4-12b-qat
LM_STUDIO_API_KEY=

# Optional isolated Qwen3 Omni realtime pilot at /omni.html.
# Leave base/key empty to reuse LM Studio settings. This requires a local
# server that actually exposes /v1/realtime; LM Studio may report unsupported.
QWEN_OMNI_BASE_URL=
QWEN_OMNI_MODEL=ggml-org/Qwen3-Omni-30B-A3B-Instruct-GGUF
QWEN_OMNI_API_KEY=
QWEN_OMNI_REQUIRE_LOCAL=1

# Optional visual observer:
# docker compose -f docker-compose.local.yml --profile vision-observer up -d smolvlm
VISION_OBSERVER_ENABLED=1
VISION_OBSERVER_INTERVAL_MS=2000
VISION_OBSERVER_MAX_CONTEXT_CHARS=1200
SMOLVLM_BASE_URL=http://smolvlm:8080
SMOLVLM_MODEL=ggml-org/SmolVLM-500M-Instruct-GGUF
SMOLVLM_API_KEY=
SMOLVLM_REQUIRE_LOCAL=1
SMOLVLM_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
SMOLVLM_HF_REPO=ggml-org/SmolVLM-500M-Instruct-GGUF
SMOLVLM_PORT=8080
SMOLVLM_N_GPU_LAYERS=99
SMOLVLM_CTX_SIZE=4096

# Optional CPU-only wake word. Disabled by default.
# Start with: docker compose -f docker-compose.local.yml --profile wake-word up -d --build wake-word ui
WAKE_WORD_ENABLED=0
WAKE_WORD_BASE_URL=http://wake-word:8081
WAKE_WORD_PHRASE=HEY EVA
WAKE_WORD_SCORE=2.5
WAKE_WORD_THRESHOLD=0.10
WAKE_WORD_FOLLOWUP_S=60
WAKE_WORD_NUM_THREADS=1
WAKE_WORD_REQUIRE_LOCAL=1

# Optional isolated Office agent. Disabled by default. Set a long random token
# shared only by the UI proxy and sidecar; it is never sent to the browser.
# Start with: docker compose -f docker-compose.local.yml --profile office-agent up -d --build office-agent ui
OFFICE_AGENT_ENABLED=0
OFFICE_AGENT_BASE_URL=http://office-agent:8082
OFFICE_AGENT_TOKEN=
OFFICE_AGENT_WORKSPACE=./agent-workspace
OFFICE_AGENT_REQUIRE_LOCAL=1
OFFICE_AGENT_REQUIRE_LOCAL_LLM=1
OFFICE_AGENT_LOCAL_LLM_PROVIDERS=lmstudio
OFFICE_AGENT_INTENT_TTL_S=60
OFFICE_AGENT_TIMEOUT_S=35

# Gemini OpenAI-compatible chat completions. Requires a Google AI Studio key.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# BGGPT OpenAI-compatible chat completions.
BGGPT_URL=https://api.bggpt.ai/v1
BGGPT_API_KEY=
BGGPT_MODEL=bggpt-gemma-3-27b

# Direct Cerebras API:
# docker compose -f docker-compose.local.yml --profile cerebras up --build
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gemma-4-31b

# Cerebras via Hugging Face Inference Providers:
# docker compose -f docker-compose.local.yml --profile hf-cerebras up --build
HF_TOKEN=
HF_CEREBRAS_MODEL=google/gemma-4-31B-it:cerebras

# Shared backend knobs
DOCKERFILE=Dockerfile
S2S_PORT=8765
S2S_BG_PORT=8766
S2S_SYSTEM_PROMPT=You are a helpful voice assistant. Keep replies short, warm, and spoken.
S2S_CHAT_SIZE=60
STT_MODEL=nvidia/parakeet-tdt-0.6b-v3
TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
PARAKEET_TDT_MODEL_NAME=nvidia/parakeet-tdt-0.6b-v3
S2S_BG_STT_LANGUAGE=bg
S2S_LLM_REQUEST_TIMEOUT_S=120
QWEN3_TTS_MAX_NEW_TOKENS=3072

# Optional prebuilt Docker Hub images for docker-compose.hub.yml.
S2S_UI_IMAGE=desy0305/hf-realtime-voice-ui:latest
S2S_BACKEND_IMAGE=desy0305/speech-to-speech-backend:latest
ANI_VOICE_IMAGE=desy0305/ani-voice-api:91722a7

# Optional Bulgarian TTS experiment:
# docker compose -f docker-compose.local.yml --profile bgtts-ani up --build
# This starts a separate LM Studio backend on S2S_BG_PORT and leaves the
# default qwen3 backend on S2S_PORT unchanged.
ANI_VOICE_REV=91722a7fdd404cca1818ace44038ed43322fc66e
ANI_VOICE_PORT=8001
ANI_VOICE_API_URL=http://ani-voice-api:8000
ANI_VOICE_STYLE=F5
ANI_VOICE_SPEED=1.6
ANI_VOICE_TIMEOUT_S=120
ANI_VOICE_BLOCKSIZE=512
ANI_VOICE_MAX_TOKENS=1024
ANI_VOICE_PRELOAD=true
ANI_VOICE_CACHE_SPEAKER=true
ANI_VOICE_WARMUP_TEXT=Здравейте.
ANI_VOICE_REFERENCE_TEXT=Здравейте, радвам се да ви помогна.
ANI_VOICE_TIMING_LOGS=true

# Optional Docker MCP gateway surface. Start/check it from PowerShell:
# powershell -ExecutionPolicy Bypass -File .\scripts\mcp\start-mcp-gateway.ps1
# powershell -ExecutionPolicy Bypass -File .\scripts\mcp\check-mcp-health.ps1
MCP_GATEWAY_URL=
MCP_GATEWAY_AUTH_TOKEN=
MCP_ALLOWED_TOOLS=mcp-find,mcp-add,mcp-remove,mcp-exec,mcp-config-set,mcp-create-profile,mcp-activate-profile,browser_navigate,browser_snapshot,browser_console_messages,browser_network_requests,browser_network_request,browser_take_screenshot,browser_wait_for,browser_click,browser_type,browser_select_option,browser_press_key,browser_fill_form,search_nodes,open_nodes,create_entities,create_relations,add_observations,sequentialthinking
